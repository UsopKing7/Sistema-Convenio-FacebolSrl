<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login</title>
    <link rel="icon" type="image/png" href="https://scontent.flpb1-2.fna.fbcdn.net/v/t39.30808-6/291736148_579153870250529_5398000145867132400_n.jpg?_nc_cat=108&ccb=1-7&_nc_sid=6ee11a&_nc_ohc=wn9fnfgK4BAQ7kNvgHQGhsa&_nc_oc=Adnm74I7gmHKJDghk1kgS-0KMkPULLun9BMqAbOonOX8nqt7PY4k7itAhpcz-AY39Lx-UsnYRP_a4NwN2h8AVMyJ&_nc_zt=23&_nc_ht=scontent.flpb1-2.fna&_nc_gid=FVJ6l7qV6Fkfd36qxeNQ1w&oh=00_AYGw3g5mbX8TQrHJq55x9ncnCANduqY_3Aqk3vs8Y-PTAg&oe=67E7E581">
    <style>
      @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&display=swap');
      
      body {
        background: linear-gradient(135deg, #0f0f0f 0%, #1a1a1a 50%, #0f0f0f 100%);
        font-family: "Poppins", sans-serif;
        display: flex;
        justify-content: center;
        align-items: center;
        height: 100vh;
        margin: 0;
        color: #f5f5f5;
      }

      .login-container {
        background: rgba(15, 15, 15, 0.85);
        backdrop-filter: blur(12px);
        padding: 2.5rem;
        border-radius: 16px;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.5), 
                    0 0 0 1px rgba(255, 255, 255, 0.05);
        width: 380px;
        text-align: center;
        animation: fadeIn 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        border: 1px solid rgba(255, 255, 255, 0.05);
      }

      h2 {
        color: #fff;
        margin-bottom: 2rem;
        font-weight: 600;
        font-size: 1.8rem;
        letter-spacing: -0.5px;
        text-shadow: 0 2px 4px rgba(0,0,0,0.2);
      }

      .form-group {
        margin-bottom: 1.5rem;
        text-align: left;
      }

      label {
        display: block;
        font-weight: 500;
        color: #e0e0e0;
        margin-bottom: 0.5rem;
        font-size: 0.95rem;
      }

      input {
        width: 100%;
        padding: 0.85rem 1rem;
        margin-top: 0.25rem;
        border: none;
        border-radius: 8px;
        font-size: 0.95rem;
        background: rgba(30, 30, 30, 0.8);
        color: #fff;
        outline: none;
        transition: all 0.3s ease;
        box-sizing: border-box;
        border: 1px solid rgba(255, 255, 255, 0.08);
      }

      input::placeholder {
        color: rgba(255, 255, 255, 0.4);
        font-weight: 300;
      }

      input:focus {
        background: rgba(40, 40, 40, 0.9);
        box-shadow: 0 0 0 2px rgba(100, 108, 255, 0.4);
        border-color: rgba(100, 108, 255, 0.4);
      }

      button {
        width: 100%;
        padding: 1rem;
        background: linear-gradient(135deg, #646cff 0%, #535bf2 100%);
        border: none;
        color: white;
        font-size: 1rem;
        border-radius: 8px;
        cursor: pointer;
        transition: all 0.3s ease;
        font-weight: 600;
        margin-top: 1rem;
        letter-spacing: 0.5px;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
      }

      button:hover {
        background: linear-gradient(135deg, #535bf2 0%, #4348b8 100%);
        box-shadow: 0 6px 12px rgba(0, 0, 0, 0.15);
        transform: translateY(-1px);
      }

      button:active {
        transform: translateY(0);
      }

      p {
        color: rgba(255, 255, 255, 0.7);
        margin-top: 1.5rem;
        font-size: 0.9rem;
      }

      a {
        text-decoration: none;
        color: #646cff;
        font-weight: 500;
        transition: color 0.2s ease;
        display: inline-block;
        margin-top: 0.5rem;
      }

      a:hover {
        color: #858bff;
        text-decoration: underline;
      }

      @keyframes fadeIn {
        from {
          opacity: 0;
          transform: translateY(-30px) scale(0.95);
        }
        to {
          opacity: 1;
          transform: translateY(0) scale(1);
        }
      }

      /* Efecto de brillo sutil en los bordes */
      .login-container::before {
        content: '';
        position: absolute;
        top: -2px;
        left: -2px;
        right: -2px;
        bottom: -2px;
        background: linear-gradient(45deg, 
                    rgba(100, 108, 255, 0.1), 
                    rgba(255, 255, 255, 0.02), 
                    rgba(100, 108, 255, 0.1));
        z-index: -1;
        border-radius: 18px;
        pointer-events: none;
        opacity: 0.7;
      }
    </style>
    <script>
      const login = async (event) => {
        event.preventDefault();

        const email = document.getElementById("email").value;
        const password = document.getElementById("password").value;

        try {
          const response = await fetch("http://localhost:3333/login", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
            },
            body: JSON.stringify({ email, password }),
          });
  
          const data = await response.json();
  
          if (response.ok) {
            window.location.href = "/companies";
          } else {
            throw new Error(data.message)
          }
        } catch (error) {
          alert("Error: " + error.message)
        }
      };
    </script>
  </head>
  <body>
    <div class="login-container">
      <h2>Iniciar Sesión</h2>
      <form onsubmit="login(event)">
        <div class="form-group">
          <label for="email">Correo Electrónico:</label>
          <input type="email" id="email" name="email" required placeholder="tu@email.com" />
        </div>
        <div class="form-group">
          <label for="password">Contraseña:</label>
          <input type="password" id="password" name="password" required placeholder="••••••••" />
        </div>
        <button type="submit">Ingresar</button>
      </form>
      <p>¿No tienes una cuenta?</p>
      <a href="registerEmpresa">Regístrate aquí</a>
    </div>
  </body>
</html>