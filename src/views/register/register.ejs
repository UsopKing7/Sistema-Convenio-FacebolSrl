<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="icon" type="image/png" href="https://scontent.flpb1-2.fna.fbcdn.net/v/t39.30808-6/291736148_579153870250529_5398000145867132400_n.jpg?_nc_cat=108&ccb=1-7&_nc_sid=6ee11a&_nc_ohc=wn9fnfgK4BAQ7kNvgHQGhsa&_nc_oc=Adnm74I7gmHKJDghk1kgS-0KMkPULLun9BMqAbOonOX8nqt7PY4k7itAhpcz-AY39Lx-UsnYRP_a4NwN2h8AVMyJ&_nc_zt=23&_nc_ht=scontent.flpb1-2.fna&_nc_gid=FVJ6l7qV6Fkfd36qxeNQ1w&oh=00_AYGw3g5mbX8TQrHJq55x9ncnCANduqY_3Aqk3vs8Y-PTAg&oe=67E7E581">
  <title>Register companies</title>
  <link rel="stylesheet" href="/register/styleRegister.css">
</head>
<body>
  <div class="register-container">
    <h2>Registrar Empresa</h2>
    <form onsubmit="registrar(event)">
      <div class="form-group">
        <label for="name">Nombre de la empresa</label>
        <input type="text" id="name" name="name" required placeholder="Ej: Tech Solutions S.A.">
      </div>
      <div class="form-group">
        <label for="email">Correo Electrónico</label>
        <input type="email" id="email" name="email" required placeholder="ejemplo@empresa.com">
      </div>
      <div class="form-group">
        <label for="phoneNumber">Teléfono celular</label>
        <input type="tel" id="phoneNumber" name="phone" required placeholder="+591 00000000">
      </div>
      <div class="form-group">
        <label for="address">Dirección</label>
        <input type="text" id="address" name="address" placeholder="Av. Principal 123">
      </div>
      <div class="form-group">
        <label for="password">Contraseña</label>
        <input type="password" id="password" name="password">
      </div>
      <button type="submit">Registrar Empresa</button>
    </form>
  </div>
  <script src="/register/script.js">
  </script>
</body>
</html>