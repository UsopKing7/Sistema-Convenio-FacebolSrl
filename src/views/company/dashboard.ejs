<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Company Dashboard</title>
</head>
<body>
  <h1>Company Dashboard</h1>
  <div id="usersList">
    <% if (users && users.length > 0) { %>
      <% users.forEach(user => { %>
        <div>
          <p>Name: <%= user.name %></p>
          <p>Email: <%= user.email %></p>
        </div>
      <% }) %>
    <% } else { %>
      <p>No users found.</p>
    <% } %>
  </div>

</body>
</html>