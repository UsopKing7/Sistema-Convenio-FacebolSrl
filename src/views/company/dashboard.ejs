<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Company Dashboard</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <link rel="stylesheet" href="/company/style.css">
</head>
<body>
  <div class="container">
    <div class="sidebar">
      <div class="sidebar-header">
        <h2>Company Dashboard</h2>
        <p>Administration Panel</p>
      </div>
      
      <div class="menu-section">
        <h3>Navigation</h3>
        <div class="menu-item active">
          <i class="fas fa-fw fa-tachometer-alt"></i>
          <span>Dashboard</span>
        </div>
        <div class="menu-item">
          <i class="fas fa-fw fa-users"></i>
          <span>Users</span>
        </div>
        <div class="menu-item">
          <i class="fas fa-fw fa-cog"></i>
          <span>Settings</span>
        </div>
      </div>
      
      <div class="logout-container">
        <form action="/logout" method="POST" class="logout-btn">
          <button type="submit" class="logout-button">
            <i class="fas fa-sign-out-alt"></i>
            <span>Logout</span>
          </button>
        </form>
      </div>
    </div>

    <div class="main-content">
      <div class="dashboard-header">
        <div class="header-info">
          <h1>User Management</h1>
          <p><strong>Company ID:</strong> <%= companyId %></p>
        </div>
      </div>

      <div id="usersList">
        <% if (users && users.length > 0) { %>
          <% users.forEach(user => { %>
            <div class="user-card">
              <div class="user-card-header">
                <div class="user-avatar">
                  <%= user.name.split(' ').map(n => n[0]).join('').toUpperCase() %>
                </div>
                <div class="user-info">
                  <h3><%= user.name %></h3>
                  <p>ID: <%= user.id %></p>
                  <p><%= user.rol %></p>
                </div>
              </div>
              
              <div class="user-details">
                <div class="user-detail">
                  <i class="fas fa-envelope"></i>
                  <span><strong>Email:</strong> <%= user.email %></span>
                </div>
                <div class="user-detail">
                  <i class="fas fa-id-card"></i>
                  <span><strong>Company ID:</strong> <%= user.companies_id %></span>
                </div>
              </div>
              
              <div class="user-role"><%= user.rol %></div>
              
              <div class="user-actions">
                <a href="/edit-user/<%= user.id %>" class="btn btn-warning">
                  <i class="fas fa-edit"></i> Edit
                </a>
                <form action="/delete-user/<%= user.id %>" method="POST" style="flex: 1;">
                  <button type="submit" class="btn btn-danger" style="width: 100%;">
                    <i class="fas fa-trash"></i> Delete
                  </button>
                </form>
              </div>
            </div>
          <% }) %>
        <% } else { %>
          <div class="no-users">
            <i class="fas fa-user-slash"></i>
            <p>No users found in the database</p>
          </div>
        <% } %>
      </div>
    </div>
    
    <a href="/registerUsers" class="add-user-btn">
      <i class="fas fa-plus"></i>
    </a>
  </div>
</body>
</html>