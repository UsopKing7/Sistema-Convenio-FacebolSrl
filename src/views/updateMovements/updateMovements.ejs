<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Editar Movimiento</title>
    <style>
        :root {
          --primary-color: #76c7c0;
          --secondary-color: #5aa6a0;
          --dark-color: #1f1f1f;
          --darker-color: #121212;
          --light-color: #e0e0e0;
          --danger-color: #ff5555;
          --warning-color: #ffaa44;
          --success-color: #1cc88a;
          --card-bg: #252525;
          --border-color: #333;
          --text-dark: #e0e0e0;
          --text-light: #b3b3b3;
        }

        body {
            font-family: 'Nunito', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            background-color: var(--darker-color);
            color: var(--text-dark);
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 20px;
            margin: 0;
        }

        form {
            background: var(--card-bg);
            padding: 30px;
            border-radius: 8px;
            width: 100%;
            max-width: 500px;
            border: 1px solid var(--border-color);
            box-shadow: 0 0.15rem 1.75rem 0 rgba(0, 0, 0, 0.2);
        }

        h1 {
            text-align: center;
            color: var(--primary-color);
            margin-bottom: 20px;
            font-size: 1.8rem;
        }

        div {
            margin-bottom: 20px;
        }

        label {
            display: block;
            margin-bottom: 8px;
            color: var(--text-dark);
            font-weight: 600;
        }

        input, textarea {
            width: 93%;
            padding: 12px 15px;
            background-color: var(--dark-color);
            border: 1px solid var(--border-color);
            border-radius: 6px;
            color: var(--text-dark);
            font-size: 1rem;
            transition: all 0.3s;
        }

        .date-display {
            background-color: var(--card-bg);
            border: 1px solid var(--border-color);
            padding: 12px 15px;
            border-radius: 6px;
            color: var(--text-light);
        }

        input:focus, textarea:focus {
            outline: none;
            border-color: var(--primary-color);
            box-shadow: 0 0 0 3px rgba(118, 199, 192, 0.2);
        }

        button {
            background-color: var(--primary-color);
            color: var(--darker-color);
            padding: 12px;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            width: 100%;
            font-size: 1rem;
            font-weight: 600;
            transition: all 0.2s;
            margin-top: 10px;
        }

        button:hover {
            background-color: var(--secondary-color);
            transform: translateY(-2px);
        }

        .back-link {
            text-align: center;
            margin-top: 20px;
            color: var(--text-light);
        }

        .back-link a {
            color: var(--primary-color);
            text-decoration: none;
            font-weight: 500;
        }

        .back-link a:hover {
            text-decoration: underline;
        }

        ::placeholder {
            color: var(--text-light);
            opacity: 0.7;
        }
        
        .required-field::after {
            content: " *";
            color: var(--danger-color);
        }
    </style>
</head>
<body>
    <form id="updateMovementForm">
        <h1>Editar Movimiento</h1>

        <div>
            <label for="amount">Monto:</label>
            <input type="number" id="amount" name="amount" placeholder="Ingrese el monto" 
                   value="<%= movement.amount %>">
        </div>
        
        <div>
            <label for="movement_type">Tipo de Movimiento:</label>
            <input type="text" id="movement_type" name="movement_type" 
                   placeholder="Ingrese el tipo de movimiento" 
                   value="<%= movement.movement_type || '' %>">
        </div>
        
        <div>
            <label for="description">Descripción:</label>
            <textarea id="description" name="description" rows="3" 
                      placeholder="Descripción del movimiento"><%= movement.description || '' %></textarea>
        </div>
        
        <div>
            <label>Fecha del Movimiento:</label>
            <div class="date-display">
                <%= new Date(movement.movement_date).toLocaleString('es-ES') %>
            </div>
        </div>
        
        <button type="submit">Actualizar Movimiento</button>
        
        <div class="back-link">
            <p><a href="/company/dashboard">Volver al Dashboard</a></p>
        </div>
    </form>

    <script>
        const form = document.getElementById('updateMovementForm');
        const movementId = "<%= movement.id %>"; // Asegúrate de que el movimiento tenga un id asignado
    
        form.addEventListener('submit', async (e) => {
            e.preventDefault();
    
            const formData = {
                amount: document.getElementById('amount').value ? 
                       parseFloat(document.getElementById('amount').value) : null,
                movement_type: document.getElementById('movement_type').value.trim() || null,
                description: document.getElementById('description').value.trim() || null
            };
    
            try {
                const response = await fetch(`/edit-movement/${movementId}`, {
                    method: 'PATCH',
                    headers: {
                        'Content-Type': 'application/json',
                        'Accept': 'application/json'
                    },
                    body: JSON.stringify(formData)
                });
    
                // Verificar si la respuesta es JSON
                const contentType = response.headers.get('content-type');
                if (!contentType || !contentType.includes('application/json')) {
                    const text = await response.text();
                    throw new Error(text || 'Respuesta no válida del servidor');
                }
    
                const result = await response.json();
    
                if (!response.ok || !result.success) {
                    throw new Error(result.message || 'Error al actualizar el movimiento');
                }
    
                alert(result.message || 'Movimiento actualizado correctamente');
                window.location.href = "/company/dashboard"; // Redirige al dashboard
            } catch (error) {
                console.error('Error:', error);
                alert('Error: ' + error.message);
            }
        });
    </script>
</body>
</html>
