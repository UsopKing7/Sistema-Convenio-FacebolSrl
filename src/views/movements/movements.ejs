<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Movements - Company <%= companyId %></title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <link rel="stylesheet" href="/company/style.css">
</head>
<body>
  <div class="container">
    <div class="sidebar">
      <div class="sidebar-header">
        <h2>Company Dashboard</h2>
        <p>Administration Panel</p>
      </div>

      <div class="menu-section">
        <h3>Navigation</h3>
        <div class="menu-item">
          <a href="/company/dashboard">
            <i class="fas fa-fw fa-users"></i>
            <span>Users</span>
          </a>
        </div>
        <div class="menu-item">
          <i class="fas fa-fw fa-cog"></i>
          <span>Settings</span>
        </div>
        <div class="menu-item">
          <i class="fas fa-right-left"></i>
          <span>Movements</span>
        </div>
      </div>

      <div class="logout-container">
        <form action="/logout" method="POST" class="logout-btn">
          <button type="submit" class="logout-button">
            <i class="fas fa-sign-out-alt"></i>
            <span>Logout</span>
          </button>
        </form>
      </div>
    </div>

    <div class="main-content">
      <div class="dashboard-header">
        <div class="header-info">
          <h1>Movements for Company </h1>
        </div>
      </div>

      <% if (movements.length > 0) { %>
        <div class="movements-list">
          <% movements.forEach(mov => { 
              const isCompra = mov.movement_type === 'compra';
              const icon = isCompra ? 'fa-arrow-down' : 'fa-arrow-up';
              const avatarClass = isCompra ? 'compra' : 'venta';
          %>
            <div class="user-card">
              <div class="user-card-header">
                <div class="user-avatar <%= avatarClass %>">
                  <i class="fas <%= icon %>"></i>
                </div>
                <div class="user-info">
                  <h3><%= mov.description %></h3>
                  <p><strong>Type:</strong> <%= mov.movement_type %></p>
                  <p><strong>Amount:</strong> Bs <%= mov.amount %></p>
                  <p><strong>Date:</strong> <%= new Date(mov.movement_date).toLocaleDateString() %></p>
                </div>
              </div>

              <div class="user-actions">
                <!-- Edit Button -->
                <a href="/edit-movement/<%= mov.id %>" class="btn btn-warning">
                  <i class="fas fa-edit"></i> Edit
                </a>
                <!-- Delete Button -->
                <a href="/delete-movement/<%= mov.id %>" class="btn btn-danger">
                  <i class="fas fa-trash"></i> Delete
                </a>
              </div>
            </div>
          <% }) %>
        </div>
        
      <% } else { %>
        <div class="no-users">
          <i class="fas fa-box-open"></i>
          <p>No movements found for this company.</p>
        </div>
      <% } %>

      <a href="/company/dashboard" class="btn btn-primary" style="margin-top: 20px;">
        <i class="fas fa-arrow-left"></i> Back to Dashboard
      </a>
    </div>
    <a href="/movements/registerMovements/<%= companyId %>" class="add-user-btn">
      <i class="fas fa-plus"></i>
    </a>
  </div>
</body>
</html>
