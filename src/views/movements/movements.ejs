<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Movements - Company</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <link rel="stylesheet" href="/company/style.css">
</head>
<body>
  <div class="container">
    <div class="sidebar">
      <div class="sidebar-header">
        <h2>Company Dashboard</h2>
        <p>Administration Panel</p>
      </div>

      <div class="menu-section">
        <h3>Navigation</h3>
        <div class="menu-item">
          <a href="/company/dashboard">
            <i class="fas fa-fw fa-users"></i>
            <span>Users</span>
          </a>
        </div>
        <div class="menu-item">
          <i class="fas fa-fw fa-cog"></i>
          <span>Settings</span>
        </div>
        <div class="menu-item">
          <i class="fas fa-right-left"></i>
          <span>Movements</span>
        </div>
      </div>

      <div class="logout-container">
        <form action="/logout" method="POST" class="logout-btn">
          <button type="submit" class="logout-button">
            <i class="fas fa-sign-out-alt"></i>
            <span>Logout</span>
          </button>
        </form>
      </div>
    </div>

    <div class="main-content">
      <div class="dashboard-header">
        <div class="header-info">
          <h1>Movements for Company</h1>
        </div>
      </div>

      <% if (movements.length > 0) { %>
        <table class="movements-table">
          <thead>
            <tr>
              <th>#</th>
              <th>Description</th>
              <th>Type</th>
              <th>Amount</th>
              <th>Date</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% movements.forEach((mov, index) => { %>
              <tr>
                <td><%= index + 1 %></td>
                <td><%= mov.description %></td>
                <td><%= mov.movement_type %></td>
                <td>Bs <%= mov.amount %></td>
                <td><%= new Date(mov.movement_date).toLocaleDateString() %></td>
                <td>
                  <a href="/edit-movement/<%= mov.id %>" class="btn btn-warning btn-sm">
                    <i class="fas fa-edit"></i> Edit
                  </a>
                  <a href="/delete-movement/<%= mov.id %>" class="btn btn-danger btn-sm">
                    <i class="fas fa-trash"></i> Delete
                  </a>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } else { %>
        <div class="no-users">
          <i class="fas fa-box-open"></i>
          <p>No movements found for this company.</p>
        </div>
      <% } %>

    </div>

    <!-- Add Movement and Refresh Button -->
    <div class="buttons-container">
      <a href="/movements/registerMovements/<%= companyId %>" class="add-user-btn">
        <i class="fas fa-plus"></i>
      </a>
      <button onclick="location.reload()" class="refresh-button">
        <i class="fas fa-sync-alt"></i>
      </button>
    </div>
  </div>
</body>
</html>
