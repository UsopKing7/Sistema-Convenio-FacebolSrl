<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Registrar Movimiento</title>
  <link rel="stylesheet" href="/movements/style.css">
</head>
<body>
<form action="/movements/registerMovements/<%= id %>" method="POST">
    <h1>Registrar Movimiento</h1>

    <input type="hidden" name="companies_id" value="<%= id %>">

    <div>
      <label for="movement_type">Tipo de Movimiento:</label>
      <input type="text" id="movement_type" name="movement_type" placeholder="Ingreso o Egreso" required>
    </div>
    

    <div>
      <label for="amount">Monto:</label>
      <input type="number" id="amount" name="amount" step="1" required>
    </div>
    
    <div>
      <label for="description">Descripción:</label>
      <textarea id="description" name="description" rows="4" required></textarea>
    </div>

    <button type="submit">Registrar Movimiento</button>

    <div>
      <p><a href="/">Volver al inicio</a></p>
    </div>
  </form>
</body>
</html>
